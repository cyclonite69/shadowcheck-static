{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "types": ["jest", "node", "geojson"]
  },
  "include": ["tests/**/*", "server/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "client",
    ".claude",
    "tests/unit/middleware/**/*",
    "tests/unit/errors/**/*",
    "tests/unit/repositories/**/*",
    "tests/unit/services/authService.test.ts"
  ]
}
